generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  LAND_OWNER
  LEASEHOLDER
}

enum UserStatus {
  INVITED
  PENDING_VERIFICATION
  ACTIVE
}

enum CropType {
  WHEAT
  BARLEY
  COTTON
  VETCH
  CLOVER
}

enum CultivationType {
  ANNUAL
  PERENNIAL
  OLIVE
  OTHER_TREES
  PASTURE
  FOREST
  OTHER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  roles         Role[]      @default([])
  status        UserStatus  @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  accounts         Account[]
  sessions         Session[]
  invites          Invite[]
  ownedFields      Field[]        @relation("FieldOwner")
  leasedFields     Field[]        @relation("FieldLeaseholder")
  cropHistories    CropHistory[]  @relation("CropHistoryLeaseholder")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Crop {
  id            String        @id @default(cuid())
  nameEl        String        @unique
  nameEn        String        @unique
  createdAt     DateTime      @default(now())
  fields        Field[]
  cropHistories CropHistory[] @relation("CropHistoryCrop")
}

model Field {
  id               String   @id @default(cuid())
  name             String
  fieldNumber      String?
  atak             String?
  kaek             String
  officialArea     Float    // m² from land registry, manually entered
  calculatedArea   Float?   // m² auto-calculated from polygon
  polygon          Json?    // GeoJSON array of { lat, lng } vertices
  cultivationType      CultivationType?
  ownershipPercentage  Float?
  cropId           String?
  ownerId          String
  leaseholderId    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  owner        User          @relation("FieldOwner", fields: [ownerId], references: [id])
  leaseholder  User?         @relation("FieldLeaseholder", fields: [leaseholderId], references: [id])
  crop         Crop?         @relation(fields: [cropId], references: [id])
  cropHistory  CropHistory[]
}

model CropHistory {
  id            String    @id @default(cuid())
  fieldId       String
  year          Int
  cropType      CropType? // kept nullable for backward compat with old enum data
  cropId        String?
  leaseholderId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  field       Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  crop        Crop? @relation("CropHistoryCrop", fields: [cropId], references: [id], onDelete: SetNull)
  leaseholder User? @relation("CropHistoryLeaseholder", fields: [leaseholderId], references: [id], onDelete: SetNull)

  @@unique([fieldId, year])
}

model Invite {
  id        String    @id @default(cuid())
  email     String
  roles     Role[]
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  userId    String?

  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
